# Скопируйте в .env и заполните. .env НЕ коммитим (см. .gitignore).

# Подключение к БД. Локально (без Docker) можно опустить — будет SQLite app.db.
# Прод (Postgres + psycopg3):
DATABASE_URL=postgresql+psycopg://hh:hh@db:5432/hh

# Параметры Postgres для docker-compose (db-сервис).
POSTGRES_USER=hh
POSTGRES_PASSWORD=change-me
POSTGRES_DB=hh

# Секрет подписи JWT. Сгенерировать: python -c "import secrets;print(secrets.token_urlsafe(48))"
APP_JWT_SECRET=

# Мастер-ключ шифрования (креды сайтов, прокси). Сгенерировать:
#   python -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
APP_ENCRYPTION_KEY=

# Анти-бан (необязательно): глобальный прокси-фолбэк, если у пользователя нет своего.
# HH_PROXY_URL=http://user:pass@host:port

# Тонкая настройка (есть дефолты):
# SESSION_IDLE_SECONDS=1800
# MAX_SESSIONS=6
# ANTIBAN_GLOBAL_MIN_SECONDS=1.5
# ANTIBAN_USER_MIN_SECONDS=3.0
